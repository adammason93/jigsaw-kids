# PWA tooling (e.g. PWABuilder/Lighthouse) often prefers manifest+json
/manifest.json
  Content-Type: application/manifest+json

# Story app must not stick on old CSS/JS at the edge — pathnames are stable; see ?v= on storybook.html
/games/storybook.html
  Cache-Control: no-cache

/games/storybook-app.css
  Cache-Control: no-cache

/games/storybook.js
  Cache-Control: no-cache
